import { len, wrapping_add as +, == } from builtins;
fn main() -> i64 {
    let xs = [ 1,2,3 ];
    let s = #{ 1, 2 };
    let d = #{ "a" : 1, "b": 2 };
    let e = #{:};
    let t = (1, "two");
    let str = "hello";
    let sl = str[1..3];
    let open = str[1..];
    let from0 = str[..2];
    mut n = 0;
    set n++;
    for (let ch : str) { set n = n+1; }
    while (n == 0) { set n = 1; }
    xs.len() + sl.len() + t.0
}
--- formatted ---
import { wrapping_add as +, ==, len } from builtins;

fn main() -> i64 {
    let xs = [1, 2, 3];
    let s = #{1, 2};
    let d = #{"a": 1, "b": 2};
    let e = #{:};
    let t = (1, "two");
    let str = "hello";
    let sl = str[1..3];
    let open = str[1..];
    let from0 = str[..2];
    mut n = 0;
    set n++;
    for (let ch : str) {
        set n = n + 1;
    }
    while (n == 0) {
        set n = 1;
    }
    xs.len() + sl.len() + t.0
}
