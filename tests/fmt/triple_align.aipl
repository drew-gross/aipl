import { print } from builtins;
fn main() !prints {
    // A `"""` raw string: the closing triple aligns with the opening (both at
    // the statement indent), and the content is shifted one level deeper,
    // keeping each line's indentation relative to the common base.
    print(
        """
        four spaces
      two spaces
    """,
    );
    // A triple-backtick template formats the same way — content one level
    // deeper — with interpolations carried along on their lines.
    let name = "world";
    print(
        ```
        indented {name}
      two spaces
    ```,
    );
}
// A mid-line opening (`... }.doc("""`): the block aligns to the opening line's
// indentation (here 0) — closing at column 0, content one level deeper.
fn documented() -> i64 { 0 }.doc("""
Line one.
Line two.
""")
--- formatted ---
import { print } from builtins;

fn main() !prints {
    // A `"""` raw string: the closing triple aligns with the opening (both at
    // the statement indent), and the content is shifted one level deeper,
    // keeping each line's indentation relative to the common base.
    print(
        """
              four spaces
            two spaces
        """,
    );

    // A triple-backtick template formats the same way — content one level
    // deeper — with interpolations carried along on their lines.
    let name = "world";
    print(
        ```
              indented {name}
            two spaces
        ```,
    );
}

// A mid-line opening (`... }.doc("""`): the block aligns to the opening line's
// indentation (here 0) — closing at column 0, content one level deeper.
fn documented() -> i64 { 0 }.doc("""
    Line one.
    Line two.
""")
