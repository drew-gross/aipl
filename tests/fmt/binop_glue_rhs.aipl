import { == } from builtins;

fn parse(s: str) -> i64 { 0 }

fn make(a: i64, b: i64, c: i64, d: i64) -> i64 { a }

fn main() -> i64 {
    // A binary operator glues to the current line (`lhs == rhs`); when the
    // line is too long the *right* operand breaks its own structure — here a
    // call's argument list — rather than the operator moving to an indented
    // continuation line of its own.
    let check = parse("a fairly long input string value") == make(11111111, 22222222, 33333333, 44444444);
    if (check) { 1 } else { 0 }
}
--- formatted ---
import { == } from builtins;

fn parse(s: str) -> i64 { 0 }

fn make(a: i64, b: i64, c: i64, d: i64) -> i64 { a }

fn main() -> i64 {
    // A binary operator glues to the current line (`lhs == rhs`); when the
    // line is too long the *right* operand breaks its own structure — here a
    // call's argument list — rather than the operator moving to an indented
    // continuation line of its own.
    let check = parse("a fairly long input string value") == make(
        11111111,
        22222222,
        33333333,
        44444444,
    );
    if (check) { 1 } else { 0 }
}
