import { !=, == } from builtins;

fn first_not_z() -> i64 {
    match ("abc"[0]) {
        some(c) => if (c != 'z') { 1 } else { 0 },
        none => 0,
    }
}.test({
    assert(first_not_z() == 1);
    assert("abc"[0] != some('z'));
})
