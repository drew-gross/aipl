import { ==, print, to_str } from builtins;

// `to_str` on a char yields its Debug-style quoted form, `'X'`.
fn main() !prints {
    let s = to_str('X');
    print(to_str(if (s == "'X'") { 1 } else { 0 })); // 1
}
