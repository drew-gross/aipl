import { execute_program, print } from builtins;

// `execute_program` has the `!execute_program` effect; a caller that doesn't
// declare it is rejected.
fn main() !prints {
    match (execute_program("echo")) {
        ok(r) => print(r.stdout),
        err(e) => print(e),
    };
}
