import { print, execute_program } from builtins;

// `args` is a keyword parameter, so it can no longer be passed positionally —
// it must be named (`execute_program("echo", args = [...])`) or omitted.
fn main() !prints !execute_program {
    match (execute_program("echo", ["a"])) {
        ok(r) => print(r.stdout),
        err(e) => print(e),
    };
}
