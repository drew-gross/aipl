import { print, to_str, wrapping_add as +, execute_program } from builtins;

// A launch failure (program not found) can't ride a separate `Error` side —
// `ExecResult` is a plain struct, not wrapped in a `Result` — so it's folded
// into the struct itself: empty `stdout`, a message in `stderr`, and
// `exit_code: -1`.
fn main() !prints !execute_program {
    let r = execute_program("no_such_binary_xyz_123", ["a", "b"]);
    print("[" + r.stdout + "][" + r.stderr + "] exit=" + to_str(r.exit_code));
}
--- stdout ---
[][could not execute program] exit=-1
