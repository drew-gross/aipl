// Passing an operator as a value still requires importing it (the desugared
// `|lhs, rhs| lhs + rhs` uses `+`), and the error points at the operator.
fn apply(a: i64, b: i64, f: (i64, i64) -> i64) -> i64 { f(a, b) }

fn main() -> i64 { apply(2, 3, +) }
--- errors ---
error: operator "+" must be imported: add `import { wrapping_add as + } from builtins;`
 --> ./tests/cases/lambdas/err_operator_value_not_imported.aipl:5:32
  |
5 | fn main() -> i64 { apply(2, 3, +) }
  |                                ^
