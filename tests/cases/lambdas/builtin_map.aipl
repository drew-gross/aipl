import { *, wrapping_add as +, ==, map, to_str } from builtins;

// `map` is a builtin: no user definition needed. It desugars to an inline loop
// in the enclosing scope, so lambdas (including capturing ones) just work.
fn doubled(xs: i64[]) -> i64[] { xs.map(|x| x * 2) }.test({
    let xs = [1, 2, 3];
    assert(xs.map(|x| x * 2) == [2, 4, 6]); // method form
    assert(map(xs, |x| x + 1) == [2, 3, 4]); // function form

    // A captured variable.
    let k = 10;
    assert(xs.map(|x| x + k) == [11, 12, 13]);

    // map may change the element type.
    assert(xs.map(|x| to_str(x)) == ["1", "2", "3"]);

    // chained / nested.
    assert(xs.map(|x| x + 1).map(|y| y * y) == [4, 9, 16]);
})
