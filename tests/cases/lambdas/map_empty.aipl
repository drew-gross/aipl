import { *, wrapping_add as +, ==, len, map, to_str } from builtins;

// Mapping an empty array yields an empty array: the lambda never runs, so the
// (possibly unknown) element type is never observed — only the empty result is.
fn empty_ints() -> i64[] { [] }.test({
    // A bare empty literal (`[]` has the placeholder element type).
    assert([].map(|x| x * 2) == []);
    assert(len([].map(|x| x * 2)) == 0);

    // A typed empty array (element type i64) from a function return.
    assert(empty_ints().map(|x| x + 1) == []);

    // A type-changing map (i64 -> str) over an empty array is still empty.
    assert(empty_ints().map(|x| to_str(x)) == []);
})
