import { wrapping_add as + } from builtins;
// The lambda's parameter count must match the expected function type.
fn apply(f: (i64) -> i64, x: i64) -> i64 {
    f(x)
}
fn main() -> i64 {
    apply(|x, y| x + y, 3)
}
