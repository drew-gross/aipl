import { !, <=, ==, >, all, filter } from builtins;

// `arr.all(pred)` is true when every element satisfies `pred` (short-circuits at
// the first that fails; an empty array is vacuously true). A higher-order
// builtin like `filter`/`map`: the lambda is lifted, captures threaded through.
// Unlike those, `all` is implemented in AIPL itself (`builtin_all.aipl`) and
// specializes like a user generic.
fn is_pos(self: i64) -> bool { self > 0 }

fn positive(xs: i64[]) -> bool { xs.all(|x| x > 0) }.test({
    assert([2, 4, 6].all(|x| x <= 6)); // every element satisfies it
    assert(![1, 2, 9].all(|x| x <= 5)); // 9 fails -> false
    assert(all([5, 5], |x| x == 5)); // free-call form
    assert([1, 2].all(is_pos)); // a named predicate, no lambda
    assert(['a', 'a', 'a'].all(|c| c == 'a')); // any comparable element type
    // Vacuously true on an empty array (a typed empty from `filter`).
    assert([1, 2].filter(|x| x > 100).all(|x| x <= 0));
    // Method-chain helper + a captured bound.
    assert(positive([1, 2, 3]));
    assert(!positive([1, 0, 3]));
})
