// An operator can be passed as a first-class function value: `apply(2, 3, +)`
// desugars to passing the binary lambda `|lhs, rhs| lhs + rhs`. It reuses all
// the lambda machinery — the receiver is monomorphized per operator. The
// operator must still be imported (the desugared `+`/`*` is gated like any use).
import { print, to_str, wrapping_add as +, * } from builtins;

fn apply(a: i64, b: i64, f: (i64, i64) -> i64) -> i64 {
    f(a, b)
}

fn main() !prints {
    let sum = apply(2, 3, +); // f(2, 3) == 2 + 3 == 5
    print(to_str(sum));
    print(to_str(apply(2, 3, *))); // 2 * 3 == 6
}
--- stdout ---
5
6
