import { wrapping_add as +, +++, print, zip_with } from builtins;

fn show_strs(label: str, xs: str[]) !prints {
    print(label);
    for (let x : xs) {
        print(x);
    }
}

fn main() !prints {
    show_strs("concat", zip_with(["a", "b", "c"], ["x", "y"], |s, t| s +++ t));
}
