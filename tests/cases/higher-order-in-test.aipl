// Regression test for lambda effect inheritance bug (fixed 2026-07-15).
// Before the fix, when a lambda was synthesized inside a .test block
// (which declares !prints and other effects), the lambda would inherit
// those effects into its ConcreteTemplate. This caused the lambda to
// carry unintended effects and could conflict with calls to the same
// lambda in different effect contexts. The fix ensures lambdas always
// start with `effects: Vec::new()`, letting the type checker determine
// which effects are actually needed from their body.
import { %, wrapping_add as +, ==, push } from builtins;

fn is_even(x: i64) -> bool { x % 2 == 0 }

fn filter_evens(arr: i64[], pred: (i64) -> bool) -> i64[] {
    mut result = [];
    for (let item : arr) {
        if (pred(item)) {
            set result.push(item);
        };
    }
    result
}.test({
    // Lambda in test block calling is_even. Without the fix, the lambda
    // would inherit !prints from the synthesized test function, causing
    // effect mismatches. With the fix, the lambda correctly has no effects.
    assert(filter_evens([1, 2, 3, 4, 5], is_even) == [2, 4]);

    // Call it again with a different array to ensure the specialization
    // is stable and works consistently.
    assert(filter_evens([10, 11, 12, 13], is_even) == [10, 12]);
})
