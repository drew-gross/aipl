import { wrapping_add as +, ==, print } from builtins;

// Both sides of a result can be `str` (heap). Constructing, matching, and `?`-
// propagating them must keep refcounts balanced — the `--- performance ---`
// alloc/dealloc counts below would diverge on a leak or double-free.
fn lookup(k: str) -> str!str {
    if (k == "x") { ok("found-x") } else { err("missing: " + k) }
}

// `?` on a `str!str`: the ok `str` is unwrapped (and owned) here; an err `str`
// is propagated to the caller. Concatenation forces fresh heap allocations.
fn greet(k: str) -> str!str {
    let v = lookup(k)?;
    ok("hello " + v)
}

fn show(r: str!str) -> str {
    match (r) {
        ok(v) => "ok(" + v + ")",
        err(e) => "err(" + e + ")",
    }
}.test({
    assert(show(greet("x")) == "ok(hello found-x)");
    assert(show(greet("y")) == "err(missing: y)");

    // Direct construction + match, no propagation.
    assert(show(ok("a")) == "ok(a)");
    assert(show(err("b")) == "err(b)");
})

fn main() !prints {
    print(show(greet("x")));
    print(show(greet("nope")));
}
--- stdout ---
ok(hello found-x)
err(missing: nope)
--- performance ---
allocations: 6
deallocations: 6
reallocations: 0
bytes allocated: 240
instructions executed: 220
binary size: 3736
--- monomorphizations ---
greet
main
show
