import { !=, wrapping_add as +, -, <, ==, print, to_str } from builtins;

// A "void with result" type `!E`: success carries no value (`ok()`), failure
// carries an error (`err(e)`). Useful for fallible effects whose only output is
// success-or-failure.
fn check_positive(n: i64) -> !str { if (n < 0) { err("negative") } else { ok() } }

// `?` on a `!E` unwraps to nothing on Ok and propagates the err otherwise —
// here driving a chain of validations whose own result is also `!E`.
fn validate(a: i64, b: i64) -> !str {
    check_positive(a)?;
    check_positive(b)?;
    ok()
}

fn describe(r: !str) -> str {
    match (r) {
        ok => "valid",
        err(e) => "invalid: " + e,
    }
}.test({
    assert(describe(validate(1, 2)) == "valid");
    assert(describe(validate(-1, 2)) == "invalid: negative");
    assert(describe(validate(1, -2)) == "invalid: negative");

    // Direct construction, match, equality, and rendering.
    assert(describe(ok()) == "valid");
    assert(ok() == ok());
    assert(ok() != err("x"));
    assert(to_str(ok()) == "ok()");
    assert(to_str(err("bad")) == "err(\"bad\")"); // to_str quotes strings
})

fn main() !prints {
    print(describe(validate(3, 4)));
    print(describe(validate(3, -4)));
    print(to_str(check_positive(5)));
}
