import { write_string_to_file } from builtins;

// `write_string_to_file` has the `!write_files` effect; a caller that doesn't
// declare it is rejected (declaring `!read_files` is not enough — it's a
// distinct effect).
fn main() !read_files {
    write_string_to_file("x.txt", "data");
}
