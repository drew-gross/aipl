// Both arguments constrain the single type parameter `T`, so they must agree.
// Here the optional's inner type (i64) and the default (char) disagree.
fn value_or<T: any>(self: T?, default: T) -> T {
    match (self) {
        some(v) => v,
        none => default,
    }
}
fn main() -> i64 {
    value_or(some(7), 'z')
}
