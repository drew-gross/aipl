import { == } from builtins;

// A bare `none` passed to an `any?` parameter pins the type variable to the
// `NoneLiteral` pseudo-type and monomorphizes the function for the none-only
// case. `match` over the param always takes the `none` arm.
fn is_present(x: any?) -> bool { match (x) { some(v) => true, none => false } }.test({
    assert(is_present(none) == false);
})
