import { ==, len } from builtins;
// Each `any[]` parameter is its own type variable, so the two arrays may
// have different element types. `same_length` is specialized on the pair
// of element types at each call site.

fn same_length(v1: any[], v2: any[]) -> bool {
    len(v1) == len(v2)
}.test({
    // i64[] vs char[], both length 3
    assert(same_length([1, 2, 3], ['a', 'b', 'c']) == true);
    // i64[] vs bool[], lengths 2 vs 3
    assert(same_length([1, 2], [true, false, true]) == false);
    // char[] vs char[], both length 1
    assert(same_length(['x'], ['y']) == true);
})
