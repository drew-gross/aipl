// An operator can be backed by a builtin (`wrapping_add as +`) or by one of
// your own functions (`my_custom_add as +`), but not both at once in the same
// file — the dispatch would be ambiguous.
import { wrapping_add as + } from builtins;
import { my_custom_add as + } from "./mymath.aipl";

fn main() -> i64 {
    2 + 3
}
