import { *, wrapping_add as +, <, ==, print, to_str } from builtins;

// Operators are imported individually by spelling, like any other builtin.

fn compute(a: i64, b: i64) -> i64 { a * b + a }.test({
    assert(compute(3, 4) == 15);
    assert(2 < 3);
})

fn main() !prints {
    print(to_str(compute(3, 4))); // 15
}
