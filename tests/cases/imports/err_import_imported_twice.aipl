// Importing the same name from two different modules is a conflict — the error
// points at both imports: the primary caret at the duplicate, a note at the
// first one.
import { val } from "./a.aipl";
import { val } from "./b.aipl";

fn main() -> i64 {
    val()
}
--- file: a.aipl ---
pub fn val() -> i64 { 1 }
--- file: b.aipl ---
pub fn val() -> i64 { 2 }
--- errors ---
error: err_import_imported_twice.aipl: import "val" conflicts with another import
 --> input:5:10
  |
5 | import { val } from "./b.aipl";
  |          ^^^
note: "val" first imported here
 --> input:4:10
  |
4 | import { val } from "./a.aipl";
  |          ^^^
