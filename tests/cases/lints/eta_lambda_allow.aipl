import { *, ==, map, to_str } from builtins;

// `#[allow]` squelches the eta-lambda lint on its line, so this forwarding
// lambda compiles and runs as written (see err_eta_lambda.aipl for the lint).
fn stringify(xs: i64[]) -> str[] {
    xs.map(|x| to_str(x)) #[allow]
}.test({
    assert(stringify([1, 2, 3]) == ["1", "2", "3"]);
})
