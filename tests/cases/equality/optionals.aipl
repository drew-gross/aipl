import { ==, !=, ! } from builtins;
// Structural equality of optionals (including nesting and comparison to `none`).
fn eq_opt(a: i64?, b: i64?) -> bool { a == b }.test({
    let a = some(5);
    let b = some(5);
    let c = some(6);
    assert(a == b);
    assert(!(a == c));
    assert(a != c);
    assert(!(a == none));

    let d = some(some(7));
    let e = some(some(7));
    let g = some(some(8));
    assert(d == e);
    assert(!(d == g));
})
