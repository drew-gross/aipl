import { ==, !=, ! } from builtins;
// Arrays compare elementwise, in order, with length first. Nested arrays and
// str elements recurse.
fn eq_arrays(a: i64[], b: i64[]) -> bool { a == b }.test({
    assert([1, 2, 3] == [1, 2, 3]);
    assert(!([1, 2, 3] == [1, 2, 4]));
    assert(!([1, 2, 3] == [1, 2]));      // length differs
    assert(!([1, 2] != [1, 2]));
    assert([] == []);

    assert(["a", "b"] == ["a", "b"]);
    assert(!(["a", "b"] == ["a", "c"]));

    assert([[1, 2], [3]] == [[1, 2], [3]]);
    assert(!([[1, 2], [3]] == [[1, 2], [4]]));
})
