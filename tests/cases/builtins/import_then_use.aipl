import { ==, len, push } from builtins;
// Builtins are usable once imported, with the same `import { .. }`
// syntax as files — just `from builtins` instead of a path.

fn pushed_len() -> i64 {
    mut xs = [1, 2];
    xs.push(3);
    len(xs)
}.test({
    assert(pushed_len() == 3);
})
