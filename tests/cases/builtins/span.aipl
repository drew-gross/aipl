import { print, to_str, ==, hash, Span } from builtins;

fn main() !prints {
    let s = Span { start: 3, end: 7 };
    print(s.start.to_str());
    print(s.end.to_str());
    print(to_str(s));
    print((s == Span { start: 3, end: 7 }).to_str());
    print((s == Span { start: 3, end: 8 }).to_str());
    print((hash(s) == hash(Span { start: 3, end: 7 })).to_str());
}
