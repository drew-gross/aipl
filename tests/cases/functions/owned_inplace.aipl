import { ==, push } from builtins;

// `extended` takes an array, appends to it, and returns it — the canonical
// "take ownership and mutate" shape. The compiler emits an in-place `$mut`
// variant: a call on a *fresh* (uniquely-owned) array moves the array in and
// reuses its buffer (the push becomes a realloc), while a call on a named
// (shared) array borrows and copies, leaving the original intact.
fn extended(xs: i64[]) -> i64[] {
    mut ys = xs;
    set ys.push(99);
    ys
}.test({
    // Fresh array literal → moved into extended$mut, mutated in place.
    assert(extended([1, 2, 3]) == [1, 2, 3, 99]);

    // Named binding → borrowed (copy); `base` is left unchanged.
    let base = [10, 20];
    assert(extended(base) == [10, 20, 99]);
    assert(base == [10, 20]);
})
--- performance ---
allocations: 7
deallocations: 7
reallocations: 0
bytes allocated: 392
instructions executed: 667
binary size: 3232
