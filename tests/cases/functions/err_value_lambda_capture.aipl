import { *, wrapping_add as +, == } from builtins;

// A lambda used as a value is a bare code address with no environment, so it
// cannot capture an enclosing local.
fn main() -> i64 {
    let n = 5;
    let f = |x: i64| { x + n };
    f(10)
}
