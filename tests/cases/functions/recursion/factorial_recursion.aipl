import { *, wrapping_add as +, wrapping_sub as -, == } from builtins;

fn fact(n: i64) -> i64 { if (n == 0) { 1 } else { n * fact(n - 1) } }.test({
    assert(fact(0) == 1);
    assert(fact(5) == 120);
})
