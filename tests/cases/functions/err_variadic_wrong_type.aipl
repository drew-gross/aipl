import { wrapping_add as + } from builtins;

// A variadic `i64*` parameter accepts an `i64`, an `i64[]`, or an `i64?` — but
// not an unrelated type. A `bool` argument fits none of those forms.
fn sum(self: i64, others: i64*) -> i64 {
    self
}

fn main() {
    let _ = 1.sum(true);
}
