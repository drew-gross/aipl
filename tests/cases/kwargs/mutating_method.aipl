// A mutating method can carry a keyword parameter after its `mut self`.
import { push, len, print, to_str } from builtins;
fn extend(mut self: i64[], v: i64 = 5) { self.push(v); }
fn main() !prints {
    mut xs = [1];
    xs.extend();
    xs.extend(v = 9);
    print(to_str(xs.len()));
}
