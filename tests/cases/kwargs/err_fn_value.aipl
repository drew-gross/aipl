// A function with keyword parameters cannot be passed as a function value:
// there is no call site to fill its defaults at, and a function type has no
// keyword parameters.
import { map, len } from builtins;
fn double(x: i64, k: i64 = 0) -> i64 { x }
fn main() -> i64 { [1].map(double).len() }
