// A generic function may declare a (concrete) keyword parameter.
import { wrapping_add as +, len, print, to_str } from builtins;
fn padded_len<T: any>(xs: T[], extra: i64 = 10) -> i64 { xs.len() + extra }
fn main() !prints {
    print(to_str(padded_len([1, 2, 3])));
    print(to_str(padded_len(["a"], extra = 1)));
}
