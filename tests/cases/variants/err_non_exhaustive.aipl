import { *, print, to_str } from builtins;

variant Shape = Circle(i64) | Rect(i64, i64) | Empty

// A `match` must cover every case of the variant.
fn area(s: Shape) -> i64 {
    match (s) {
        Circle(r) => r * r,
        Empty => 0,
    }
}

fn main() !prints {
    print(to_str(area(Empty)));
}
