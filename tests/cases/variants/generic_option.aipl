import { ==, print, to_str } from builtins;

// A generic variant. Used at a single type argument here (`Opt<i64>`), its
// instance `Opt$i64` is an ordinary variant whose constructors resolve like
// any other. (A variant may currently be instantiated at only one type.)
variant Opt<T> = Some(T) | Nothing

fn or_default(o: Opt<i64>, d: i64) -> i64 {
    match (o) {
        Some(v) => v,
        Nothing => d,
    }
}

fn main() !prints {
    print(to_str(or_default(Some(5), 0)));
    print(to_str(or_default(Nothing, 9)));
}
