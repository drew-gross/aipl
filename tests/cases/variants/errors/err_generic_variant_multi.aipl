// A generic variant may currently be instantiated at only one type argument,
// because its constructors are shared by name across instances.
variant Opt<T> = Some(T) | Nothing

fn as_int(o: Opt<i64>) -> i64 {
    match (o) {
        Some(v) => v,
        Nothing => 0,
    }
}

fn as_str(o: Opt<str>) -> str {
    match (o) {
        Some(v) => v,
        Nothing => "",
    }
}

fn main() -> i64 { 0 }
