import { wrapping_add as +, ==, len, push, value_or } from builtins;

// A `str[]` is an array whose elements are heap-allocated strings. Build,
// index (yields `str?`), push, and iterate — each operation retains/releases
// the element strings so nothing leaks or double-frees. `ys` snapshots `xs`
// before pushing, so `xs` stays length 2 (value semantics).
fn appended(xs: str[], s: str) -> str[] {
    mut ys = xs;
    set ys.push(s);
    ys
}.test({
    let xs = ["foo", "bar"];
    mut ys = xs;
    set ys.push("baz");
    // index yields str?
    assert(ys[0] == some("foo"));
    assert(ys == ["foo", "bar", "baz"]);
    mut count = 0;
    for (let s : ys) {
        set count = count + 1;
    }
    assert(count == 3);
    // xs is unchanged (len 2)
    assert(xs == ["foo", "bar"]);
    assert(len(xs) == 2);
    assert(len(ys) == 3);
    assert(appended(xs, "baz") == ["foo", "bar", "baz"]);
})
