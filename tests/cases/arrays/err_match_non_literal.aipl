import { wrapping_add as +, print, to_str } from builtins;

// Array-pattern elements must be literals, not computed expressions.
fn code(xs: i64[]) -> i64 {
    let k = 2;
    match (xs) {
        [1, k + 1] => 1,
        _ => 0,
    }
}

fn main() !prints {
    print(to_str(code([1, 2])));
}
