import { wrapping_sub as -, print, to_str } from builtins;

// Optionals nest: `some(some(1))` is an `i64??`, stored inline (the outer's
// value region holds the whole inner optional). And indexing a `T?[]` yields a
// genuine `T??` — no flattening — so an out-of-bounds index (outer `none`) is
// distinct from an element that is itself `none`.
fn main() !prints {
    // Nested optional construction + Debug-style rendering.
    print(to_str(some(some(1)))); // some(some(1))

    // Indexing `i64?[]` → `i64??`.
    let xs = [some(1), none, some(3)];
    print(to_str(xs[0])); // some(some(1))   (in bounds, element some(1))
    print(to_str(xs[1])); // some(none)      (in bounds, element none)
    print(to_str(xs[9])); // none            (out of bounds)

    // Nested match distinguishes out-of-bounds, present-but-none, and a value.
    let n0 = match (xs[0]) {
        some(inner) => match (inner) {
            some(v) => v,
            none => -1,
        },
        none => -2,
    };
    let n1 = match (xs[1]) {
        some(inner) => match (inner) {
            some(v) => v,
            none => -1,
        },
        none => -2,
    };
    let n9 = match (xs[9]) {
        some(inner) => match (inner) {
            some(v) => v,
            none => -1,
        },
        none => -2,
    };
    print(to_str(n0)); // 1
    print(to_str(n1)); // -1   (present, inner none)
    print(to_str(n9)); // -2   (out of bounds)

    // `str?[]` indexed → `str??` — exercises nested-optional heap refcounting;
    // a leak or double-free would unbalance the alloc counts.
    let ss = [some("hi"), none];
    print(to_str(ss[0])); // some(some("hi"))
    print(to_str(ss[1])); // some(none)
}
--- stdout ---
some(some(1))
some(some(1))
some(none)
none
1
-1
-2
some(some("hi"))
some(none)
--- performance ---
allocations: 7
deallocations: 7
reallocations: 0
bytes allocated: 291
instructions executed: 790
binary size: 6880
--- monomorphizations ---
main
