import { ==, push } from builtins;

// Aliasing disables the in-place optimization: once `a` is bound to `b`, the
// static analysis marks `a` non-exclusive, so further pushes copy-on-grow and
// the snapshot `b` is never mutated underneath us. Several pushes (enough to
// have triggered in-place relocation were `a` exclusive) confirm `b` stays put.
fn appended(xs: i64[], x: i64) -> i64[] {
    mut ys = xs;
    set ys.push(x);
    ys
}.test({
    mut a = [1];
    set a.push(2);
    set a.push(3);
    let b = a; // snapshot of [1, 2, 3]
    set a.push(4);
    set a.push(5);
    set a.push(6);
    assert(a == [1, 2, 3, 4, 5, 6]);
    assert(b == [1, 2, 3]); // unchanged
})
