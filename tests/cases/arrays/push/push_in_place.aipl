import { ==, push } from builtins;

// `xs.push(x)` appends to `xs` in place: the same variable holds the longer
// array afterward (no reassignment needed).
fn grown() -> i64[] {
    mut xs = [5];
    set xs.push(6);
    set xs.push(7);
    xs
}.test({
    assert(grown() == [5, 6, 7]);
})
