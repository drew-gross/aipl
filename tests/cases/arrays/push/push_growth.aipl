import { ==, push } from builtins;

// Growable arrays: start from an empty literal and push. `xs.push(x)` grows
// the array variable in place. Snapshotting it first (`let b = a`) keeps `b`
// independent — pushing to `a` afterward doesn't change `b` (value semantics).
fn appended(xs: i64[], x: i64) -> i64[] {
    mut ys = xs;
    ys.push(x);
    ys
}.test({
    mut a = [];
    a.push(1);
    a.push(2);
    a.push(3);
    let b = a; // snapshot of [1, 2, 3]
    a.push(4); // grows a only
    assert(a == [1, 2, 3, 4]);
    assert(b == [1, 2, 3]); // b stays [1, 2, 3]
    assert(appended(b, 4) == [1, 2, 3, 4]);
    assert(b == [1, 2, 3]);
})
