import { Span, print, to_str } from builtins;

// The `xs[span]` Span-index sugar (see strings/slice_span.aipl) slices arrays
// too: it's sugar for `xs[span.start..span.end]`, with the same clamping.
fn main() !prints {
    let xs = [10, 20, 30, 40, 50];
    let s = Span { start: 1, end: 4 };
    print(xs[s].to_str()); // [20, 30, 40]
    print(xs[Span { start: 3, end: 99 }].to_str()); // [40, 50]  (end clamped)
}
--- stdout ---
[20, 30, 40]
[40, 50]
--- performance ---
allocations: 5
deallocations: 5
reallocations: 0
bytes allocated: 230
instructions executed: 707
binary size: 2528
