import { wrapping_add as +, wrapping_sub as -, == } from builtins;

// Indexing yields an optional: some(elem) in bounds, none out of bounds.
fn at(xs: i64[], i: i64) -> i64 {
    match (xs[i]) {
        some(v) => v,
        none => -1,
    }
}.test({
    let xs = [5, 6, 7];
    // in-bounds element
    assert(at(xs, 1) == 6);
    // out-of-bounds -> -1
    assert(at(xs, 10) == -1);
    // negative index -> -1
    assert(at(xs, -1) == -1);
    // indexing directly yields an optional
    assert(xs[0] == some(5));
    assert(xs[9] == none);
})
