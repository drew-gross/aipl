import { print, reverse, to_str } from builtins;

// Array slicing `xs[start..end]` yields a fresh array of the elements in
// `[start, end)`. Both bounds clamp to `[0, len]` (an out-of-range end gives a
// shorter array, `start >= end` gives `[]`), and the open-ended forms run to
// the array's edges. The slice copies (and co-owns) its elements; the source
// is unchanged.
fn main() !prints {
    let xs = [10, 20, 30, 40, 50];
    print(xs[1..4].to_str()); // [20, 30, 40]
    print(xs[..2].to_str()); // [10, 20]
    print(xs[2..].to_str()); // [30, 40, 50]
    print(xs[3..100].to_str()); // [40, 50]  (end clamped to len)
    print(xs[4..2].to_str()); // []  (start > end)
    print(xs.to_str()); // the source is unchanged

    // Heap elements are co-owned: the slice and the source stay independently
    // usable (and independently droppable).
    let ss = ["a", "bb", "ccc", "dddd"];
    let mid = ss[1..3];
    print(mid.to_str()); // ["bb", "ccc"]
    print(ss.to_str()); // ["a", "bb", "ccc", "dddd"]
    // `bool[]` is bit-packed; the slice start need not be byte-aligned.
    let bs = [true, false, true, true, false];
    print(bs[1..4].to_str()); // [false, true, true]
    // A reversed-view source reads its elements through the view.
    print(xs.reverse()[1..3].to_str()); // [40, 30]
}
