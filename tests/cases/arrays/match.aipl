import { print, to_str } from builtins;
// `match` on an array: each arm is an array literal, matched by exact length +
// elementwise equality, with a required `_` default as the last arm. The
// elements are literals (validated by the checker).
fn code(xs: i64[]) -> i64 {
    match (xs) {
        [1, 2, 3] => 1,
        [4, 5] => 2,
        [] => 3, // the empty array matches only [] (exact length 0)
        _ => 0,
    }
}

fn label(xs: str[]) -> str {
    match (xs) {
        ["a", "b"] => "ab",
        // "greeting" is an 8-byte (tracked static) literal — exercises compiling
        // a heap-str pattern element in the dominating block.
        ["greeting", "msg"] => "found",
        _ => "other",
    }
}

fn main() !prints {
    print(to_str(code([1, 2, 3]))); // 1
    print(to_str(code([4, 5]))); // 2
    print(to_str(code([]))); // 3
    print(to_str(code([1, 2]))); // 0  (length mismatch with [1,2,3])
    print(to_str(code([1, 2, 4]))); // 0  (element mismatch)
    print(label(["a", "b"])); // ab
    print(label(["greeting", "msg"])); // found
    print(label(["x"])); // other
}
