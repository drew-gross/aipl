import { print, to_str } from builtins;

// An array match is open-domain, so it must end with a `_` default arm.
fn code(xs: i64[]) -> i64 {
    match (xs) {
        [1, 2] => 1,
        [3, 4] => 2,
    }
}

fn main() !prints {
    print(to_str(code([1, 2])));
}
