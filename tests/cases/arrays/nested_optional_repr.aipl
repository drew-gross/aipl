import { -, print, to_str, is_some } from builtins;

// The flattened optional representation: an optional chain `Optional^n(Core)` is
// `{ tag: i64, value: <Core> }` — a single core-sized value field shared by the
// whole chain, with the tag (0..=n) counting the present `some` layers. So
// `i64????` is 16 bytes (8 tag + 8 value), the same as `i64?`, no matter how
// deep the nesting; only the tag's range grows.
fn main() !prints {
    // Four `some` layers — the tag reaches 4, the value field still holds one
    // i64. Rendering walks the tag back down to the core.
    let a = some(some(some(some(42))));
    print(to_str(a));            // some(some(some(some(42))))

    // `is_some` tests only the outermost layer (any nonzero tag).
    print(to_str(a.is_some()));  // true

    // Peel all four layers with nested matches.
    let v = match (a) {
        some(x1) => match (x1) {
            some(x2) => match (x2) {
                some(x3) => match (x3) { some(x4) => x4, none => -1 },
                none => -2,
            },
            none => -3,
        },
        none => -4,
    };
    print(to_str(v));            // 42

    // A `str????` (heap core, deep): the str is owned only at the full tag, so
    // refcounting stays balanced through construction, rendering, and teardown.
    let s = some(some(some(some("deep"))));
    print(to_str(s));            // some(some(some(some("deep"))))
}
--- stdout ---
some(some(some(some(42))))
true
42
some(some(some(some("deep"))))
