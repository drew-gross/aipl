import { !, ==, has, len } from builtins;

// Set literals dedup at construction; `has`/`len` query them.
fn build() -> #{i64} {
    #{1, 2, 3, 2, 1} // duplicates dropped -> {1, 2, 3}
}.test({
    let s = build();
    assert(s == #{1, 2, 3});
    assert(len(s) == 3);
    assert(s.len() == 3); // method form
    assert(s.has(2));
    assert(!s.has(5));
    assert(has(s, 3)); // call form

    let empty = #{};
    assert(len(empty) == 0);
    assert(!empty.has(7));
})
