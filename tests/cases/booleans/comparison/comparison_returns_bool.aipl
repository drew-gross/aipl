import { ==, <, ! } from builtins;
// `<` returns bool, so it can feed `!`.
fn not_lt(x: i64, y: i64) -> bool { !(x < y) }.test({
    assert(not_lt(3, 5) == false);
    assert(not_lt(5, 3) == true);
})
