import { &&, ==, || } from builtins;

fn and(x: bool, y: bool) -> bool { x && y }.test({
    assert(and(true, false) == false);
    assert(and(true, true) == true);
})

fn or(x: bool, y: bool) -> bool { x || y }.test({
    assert(or(false, true) == true);
    assert(or(false, false) == false);
})
