import { == } from builtins;
fn flag(b: bool?) -> i64 {
    match (b) {
        some(v) => if (v) { 1 } else { 0 },
        none => 0
    }
}.test({
    assert(flag(some(true)) == 1);
    assert(flag(some(false)) == 0);
    assert(flag(none) == 0);
})
