import { ==, print, to_str } from builtins;

// A string-literal pattern only matches a `str` scrutinee, not an optional.
fn label(x: i64?) -> str { match (x) { "a" => "x", _ => "y" } }

fn main() !prints {
    print(label(some(1)));
}
