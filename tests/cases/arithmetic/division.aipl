import { wrapping_add as +, wrapping_sub as -, /, == } from builtins;

fn d(x: i64, y: i64) -> i64 { x / y }.test({
    // Truncating division (rounds toward zero): 20/4 = 5, -10/3 = -3.
    assert(d(20, 4) == 5);
    assert(d(-10, 3) == -3);
    assert(d(20, 4) + d(-10, 3) == 2);
})
