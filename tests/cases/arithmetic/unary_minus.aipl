import { wrapping_add as +, wrapping_sub as -, == } from builtins;

fn neg(x: i64) -> i64 { -x }.test({
    assert(neg(5) == -5);
    assert(neg(-7) == 7);
    // neg(5) - (-5) + neg(-7) - 7 == 0
    assert(neg(5) + 5 + neg(-7) - 7 == 0);
})
