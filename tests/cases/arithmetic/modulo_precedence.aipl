import { %, wrapping_add as +, == } from builtins;

// 10 % 3 == 1, so 2 + 1 == 3 (not (2 + 10) % 3 == 0).
fn f() -> i64 { 2 + 10 % 3 }.test({
    assert(f() == 3);
})
