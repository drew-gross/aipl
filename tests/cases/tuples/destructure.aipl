import { wrapping_add as +, print, to_str } from builtins;

fn main() !prints {
    let my_tuple = (1, "two", 3);
    let (a, b, c) = my_tuple;
    print(to_str(a));
    print(b);
    print(to_str(c));
    let (x, y) = (10, 20);
    print(to_str(x + y));
}
