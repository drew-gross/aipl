import { saturating_sub as -, <, == } from builtins;

// `import { saturating_sub as - }` binds `-` to clamping integer subtraction:
// instead of wrapping on overflow (`wrapping_sub`), the result is pinned at the
// type's bound. The operator resolves to the `saturating_sub` builtin, so the
// same `a - b` spelling means saturating here and wrapping in a file that
// imported `wrapping_sub as -`. Unary negation (`-x`) is unaffected.
fn probe() -> bool { true }.test({
    // In range: exact difference, same as any subtraction.
    assert(i8(30) - i8(20) == 10);
    assert(u8(150) - u8(50) == 100);
    assert(10 - 3 == 7);

    // Signed narrow: clamp at the min and max on over/underflow.
    assert(i8(-100) - i8(100) == -128);
    assert(i8(100) - i8(-100) == 127);
    assert(i16(-30000) - i16(10000) == -32768);
    assert(i16(30000) - i16(-10000) == 32767);
    assert(i32(-2000000000) - i32(2000000000) == -2147483648);

    // Unsigned narrow: underflow floors at 0 (a smaller minus larger).
    assert(u8(50) - u8(100) == 0);
    assert(u16(10000) - u16(60000) == 0);
    assert(u32(1000000000) - u32(4000000000) == 0);

    // 64-bit signed: a large underflow saturates toward i64::MIN, which stays
    // very negative (a wrapping sub would flip it positive). i64::MIN itself has
    // no literal (its magnitude exceeds i64::MAX), so compare instead.
    assert(-9000000000000000000 - 9000000000000000000 < -9000000000000000000);
    // Unsigned 64-bit underflow floors at 0.
    assert(u64(3) - u64(9) == 0);
})
