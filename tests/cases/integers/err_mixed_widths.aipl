import { wrapping_add as + } from builtins;

// Only bare *literals* flex to a narrow type — two different-width integer
// *values* still need an explicit conversion to combine.
fn combine(a: i32, b: i8) -> i32 { a + b }

fn main() -> i64 { 0 }
