import { == } from builtins;

struct Point { x: i64 = 0, y: i64 = 0 }

struct Config { retries: i64 = 3, label: str = "default" }

fn all_defaults() -> Point { Point {} }.test({
    assert(all_defaults().x == 0);
    assert(all_defaults().y == 0);
})

fn partial_x() -> Point { Point { x: 5 } }.test({
    assert(partial_x().x == 5);
    assert(partial_x().y == 0);
})

fn partial_y() -> Point { Point { y: 7 } }.test({
    assert(partial_y().x == 0);
    assert(partial_y().y == 7);
})

fn all_explicit() -> Point { Point { x: 3, y: 4 } }.test({
    assert(all_explicit().x == 3);
    assert(all_explicit().y == 4);
})

fn config_defaults() -> Config { Config {} }.test({
    assert(config_defaults().retries == 3);
    assert(config_defaults().label == "default");
})

fn config_override() -> Config { Config { label: "custom" } }.test({
    assert(config_override().retries == 3);
    assert(config_override().label == "custom");
})

// A string-literal default is materialized at every construction site that
// omits the field, each carrying the default expression's one span — so the
// span-derived data symbol repeats. Two such sites (here and in
// `config_defaults` above) reuse the single definition rather than colliding.
fn label_here() -> str { Config {}.label }.test({
    assert(label_here() == "default");
})
