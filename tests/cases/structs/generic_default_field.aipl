import { == } from builtins;

// A generic struct may mix a type-parameter field with an ordinary field that
// carries a default. The default rides along with each instantiation.
struct Tagged<T> { value: T, tag: str = "none" }

fn default_tag() -> str { Tagged { value: 7 }.tag }.test({
    assert(default_tag() == "none");
})

fn custom_tag() -> str { Tagged { value: 7, tag: "seven" }.tag }.test({
    assert(custom_tag() == "seven");
})

fn value_through() -> i64 { Tagged { value: 99 }.value }.test({
    assert(value_through() == 99);
})
