import { print, to_str } from builtins;

struct Point { x: i64, y: i64 }
struct LineAt { line: i64, line_start: i64 }

fn main() !prints {
    let p = Point { x: 10, y: 20 };
    let Point { x, y } = p;
    print(to_str(x));
    print(to_str(y));
    let la = LineAt { line: 3, line_start: 42 };
    let LineAt { line, line_start } = la;
    print(to_str(line));
    print(to_str(line_start));
}
