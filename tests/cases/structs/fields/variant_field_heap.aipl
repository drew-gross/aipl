import { *, +++, ==, print, to_str } from builtins;

// A variant field whose payload owns heap (`str`): constructing the struct
// retains the payload, dropping the struct releases it (the asserted
// alloc/dealloc balance below proves ownership is threaded through the field).
variant Name = Anon | Named(str)

struct Person { name: Name, age: i64 }

fn label(p: Person) -> str {
    match (p.name) {
        Anon => "anon",
        Named(n) => n,
    }
}

fn rename(p: Person, n: str) -> Person { Person { name: Named(n), age: p.age } }

fn main() !prints {
    let p = Person { name: Named("al" +++ "ice"), age: 30 };
    print(label(p));
    print(label(Person { name: Anon, age: 1 }));
    // Struct with a variant field round-trips through a function return.
    let q = rename(p, "bob");
    print(label(q));
    // Rendering recurses through the field into the active case's payload.
    print(to_str(q));
}
--- stdout ---
alice
anon
bob
Person { name: Named("bob"), age: 30 }
--- performance ---
allocations: 2
deallocations: 2
reallocations: 0
bytes allocated: 95
instructions executed: 322
binary size: 4248
--- monomorphizations ---
label
main
