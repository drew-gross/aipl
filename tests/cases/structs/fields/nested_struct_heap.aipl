import { wrapping_add as +, ==, value_or } from builtins;

// A nested struct that holds heap data: the inner `Name` owns two `str`s (built
// by concatenation, so they're genuinely heap-allocated, not static literals),
// and `Contact` holds an optional too. The outer struct co-owns the inner's
// heap fields, so the balanced alloc/dealloc count below proves each string is
// retained on construction and released exactly once when the struct drops.
struct Name { first: str, last: str }
struct Contact { name: Name, nick: str? }

fn full_first(c: Contact) -> str {
    c.name.first
}.test({
    let c = Contact {
        name: Name { first: "Ad" + "a", last: "Love" + "lace" },
        nick: some("Count" + "ess"),
    };
    assert(full_first(c) == "Ada");          // heap str through two struct levels
    assert(c.name.last == "Lovelace");
    assert(c.nick.value_or("(none)") == "Countess"); // optional field on outer
})
--- performance ---
allocations: 3
deallocations: 3
reallocations: 0
bytes allocated: 120
instructions executed: 164
binary size: 3832
--- monomorphizations ---
main
