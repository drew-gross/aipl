import { ==, > } from builtins;
// What happens when a user writes a failing test: `aipl check` reports each
// failed assertion (with its source location) under a per-test FAIL header and
// exits non-zero. The `--- check ---` section below pins that exact report.
// `one`'s test passes (so it's silent); only `answer`'s test fails.

fn one() -> i64 { 1 }.test({
    assert(one() == 1);
})

fn answer() -> i64 { 41 }.test({
    assert(answer() == 42);
    assert(answer() > 100);
})

fn main() {}
--- check ---
test answer ... FAIL
  assert failed at input:12: answer() == 42
  assert failed at input:13: answer() > 100
2 tests: 1 passed, 1 failed
--- performance ---
allocations: 0
deallocations: 0
reallocations: 0
bytes allocated: 0
instructions executed: 4
binary size: 552
--- monomorphizations ---
main
