import { wrapping_add as +, -, ==, print, to_str, len, get, contains_key, value_or } from builtins;

// Exercises the `aipl check` path (run by the cases harness on every `.test`
// case) across a few value kinds: i64, str, array, and dict. The `main` run is
// what the harness checks for stdout/perf; the `.test` blocks run under `check`.

fn add(a: i64, b: i64) -> i64 { a + b }.test({
    assert(add(2, 3) == 5);
    assert(add(-1, 1) == 0);
})

fn greet(name: str) -> str { "hi " + name }.test({
    assert(greet("al") == "hi al");
    assert(greet("") == "hi ");
})

fn first_three() -> i64[] { [1, 2, 3] }.test({
    assert(len(first_three()) == 3);
    assert(first_three() == [1, 2, 3]);
})

fn ages() -> #{str: i64} { #{"al": 30, "mo": 25} }.test({
    assert(ages().get("al").value_or(0) == 30);
    assert(ages().contains_key("mo"));
    assert(len(ages()) == 2);
})

fn main() !prints {
    print("ok");
}
