import { wrapping_add as + } from builtins;

// A mutating method needs a mutable receiver; a `let` binding can't be mutated.
fn add(mut self: i64, x: i64) {
    set self = self + x;
}

fn main() -> i64 {
    let n = 1;
    set n.add(2);
    n
}
--- errors ---
error: set: cannot assign to immutable binding "n" (use "let mut")
  --> ./tests/cases/methods/mutating/err_immutable_receiver.aipl:10:9
