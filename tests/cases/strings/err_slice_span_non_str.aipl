import { Span, len } from builtins;

// A `Span` index is slice sugar, and slicing only supports `str` receivers —
// a `Span` index on an array is rejected like any other slice of an array.
fn main() -> i64 {
    let xs = [1, 2, 3];
    let s = Span { start: 0, end: 2 };
    xs[s].len()
}
