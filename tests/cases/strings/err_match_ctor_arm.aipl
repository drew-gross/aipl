import { ==, print } from builtins;

// A `str` match takes string-literal arms (and `_`), not constructor patterns.
fn label(s: str) -> str {
    match (s) {
        some(v) => v,
        _ => "default",
    }
}

fn main() !prints {
    print(label("a"));
}
