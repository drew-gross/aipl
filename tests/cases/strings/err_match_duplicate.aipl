import { ==, print } from builtins;

// A repeated string-literal arm is dead code.
fn label(s: str) -> str {
    match (s) {
        "a" => "x",
        "a" => "y",
        _ => "z",
    }
}

fn main() !prints {
    print(label("a"));
}
