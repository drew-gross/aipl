// Small String Optimization (SSO): a string of <= 7 bytes is stored *inline* in
// the 8-byte str value itself — no heap allocation, no refcount. Short literals,
// concatenation, trim, and `to_str` of small values all stay inline, so the
// `--- performance ---` counters below show ZERO heap activity. (A string of >= 8
// bytes still allocates; see the other string cases.) SSO is invisible to program
// semantics — these print exactly as a heap-backed string would.
import { wrapping_add as +, print, to_str, trim } from builtins;

fn main() !prints {
    let greeting = "hi"; // inline literal (2 bytes)
    let banged = greeting + "!"; // inline concat -> "hi!" (3 bytes)
    print(banged);
    print(trim("  ok  ")); // inline trim result -> "ok" (2 bytes)
    print(to_str(42)); // inline to_str -> "42" (2 bytes)
    print(""); // the empty string is inline too (a blank line)
}
--- stdout ---
hi!
ok
42

--- performance ---
allocations: 1
deallocations: 1
reallocations: 0
bytes allocated: 40
instructions executed: 50
binary size: 1648
--- monomorphizations ---
main
