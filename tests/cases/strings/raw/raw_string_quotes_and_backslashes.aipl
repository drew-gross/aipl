import { print } from builtins;

// Raw strings are verbatim: embedded quotes (`"`, `""`) and backslashes are
// ordinary characters (no escapes), and a single-line raw string isn't
// de-dented. Both lines print exactly as written.
fn main() !prints -> i64 {
    print("""path C:\dir\new "quoted" and ""doubled"" end""");
    let multi = """
        line "with" quotes
        and a \backslash
    """;
    print(multi);
    0
}
