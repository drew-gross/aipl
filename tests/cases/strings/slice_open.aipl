import { == } from builtins;

// `s[start..]` slices from `start` to the end of the string (the open end runs
// to `s`'s length, filled in by codegen — no `len` import needed). `start` is
// clamped to `[0, len]`, like the closed `s[start..end]` form.
fn drop_prefix(s: str, n: i64) -> str {
    s[n..]
}.test({
    assert("hello"[0..] == "hello");        // whole string
    assert("hello"[2..] == "llo");          // from the 3rd byte
    assert("hello"[5..] == "");             // start == len -> empty
    assert("hello"[10..] == "");            // start past end -> clamped to empty
    assert(drop_prefix("abcdef", 4) == "ef"); // 5th byte onward
    assert(""[0..] == "");                  // empty source
    // The closed form still works (regression).
    assert("hello"[1..3] == "el");
})
