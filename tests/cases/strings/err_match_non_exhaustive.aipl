import { ==, print } from builtins;

// A `str` match is open-domain, so it must end with a `_` default arm.
fn label(s: str) -> str {
    match (s) {
        "a" => "x",
        "b" => "y",
    }
}

fn main() !prints {
    print(label("a"));
}
